{
  "name": "@nurutomo/js-games",
  "version": "0.0.1",
  "description": "A collection of games implemented in JavaScript/TypeScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc -P tsconfig.build.json",
    "prepack": "npm run build",
    "prepare": "npm run build",
    "test": "tsx ./node_modules/mocha/bin/mocha.js --recursive \"**/*.test.ts\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nurutomo/js-games.git"
  },
  "keywords": [
    "nodejs",
    "typescript"
  ],
  "author": "MynBites",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/nurutomo/js-games/issues"
  },
  "homepage": "https://github.com/nurutomo/js-games#readme",
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.3",
    "mocha": "^11.1.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
